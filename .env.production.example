# This is a template file - copy to .env.production and fill in your values

# Supabase Credentials
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Google Sign-In (native ID-token flow). From Google Cloud Console (Phase 0).
# WEB client id is used as the Android serverClientId; IOS client id is used on iOS.
# Leave blank to disable the Google button at runtime.
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# API Base URL
API_BASE_URL=https://api.360ghar.com

# Google Places API Key (for location search)
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Firebase Feature Flags (Production)
FIREBASE_ENABLED=true
FIREBASE_CRASHLYTICS=true
FIREBASE_ANALYTICS=true
FIREBASE_PERFORMANCE=true
FIREBASE_IAM=true

# Firebase App Check
FIREBASE_APPCHECK=true
# For Web App Check (optional). Provide your reCAPTCHA v3 site key to enable on web
# RECAPTCHA_V3_SITE_KEY=your-recaptcha-v3-site-key

# Debugging Flags (Production - disable)
DEBUG_MODE=false
LOG_API_CALLS=false
